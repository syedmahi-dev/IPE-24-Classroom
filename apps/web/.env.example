# apps/web/.env.example
# Copy this file to .env and fill in real values
# NEVER commit .env to git

# ── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ipe24:CHANGE_THIS_PASSWORD@postgres:5432/ipe24_db
# Optional: separate sandbox DB for Virtual CR knowledge mirror
# If set, discord knowledge + routine sync data are copied here.
VIRTUAL_CR_SANDBOX_DATABASE_URL=postgresql://ipe24:CHANGE_THIS_PASSWORD@postgres:5432/ipe24_virtual_cr_sandbox

# ── CACHE ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── AUTH ─────────────────────────────────────────────────────────────────────
# Your deployed URL (no trailing slash)
NEXTAUTH_URL=https://your-domain.me
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=GENERATE_WITH_OPENSSL_RAND_HEX_32

# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=XXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXX

# Only users with this domain can sign in
ALLOWED_DOMAIN=iut-dhaka.edu

# ── GOOGLE APIS (Service Account) ────────────────────────────────────────────
# Generate with: base64 -w 0 service-account-key.json
GOOGLE_SERVICE_ACCOUNT_KEY=BASE64_ENCODED_SERVICE_ACCOUNT_JSON

# From Google Drive — right-click the class folder → Share → copy ID from URL
GOOGLE_DRIVE_FOLDER_ID=1ABC_YOUR_FOLDER_ID_HERE

# From Google Sheets URL: docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEETS_ROUTINE_ID=YOUR_SPREADSHEET_ID_HERE

# ── AI ───────────────────────────────────────────────────────────────────────
# From https://aistudio.google.com/app/apikey (free)
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXX

# ── INTERNAL API ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Used by n8n, Discord bot, WhatsApp bot to call internal endpoints
INTERNAL_API_SECRET=GENERATE_WITH_OPENSSL_RAND_HEX_32

# ── PUSH NOTIFICATIONS ───────────────────────────────────────────────────────
# Firebase public config (from Firebase Console → Project Settings → General → Web app)
# These are optional — hardcoded fallbacks exist in firebaseClient.ts and firebase-messaging-sw.js
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyXXXX
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxx
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# From Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
NEXT_PUBLIC_FCM_VAPID_KEY=BNT-XXXX
# From Firebase Console → Project Settings → Service Accounts → Generate new private key
# base64 encode the JSON: base64 -w 0 firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_KEY=BASE64_ENCODED_FIREBASE_JSON
